# ============================================
# ONADROADNOW - Complete Environment Variables
# Generated from all .env files in the system
# ============================================

# Authentication
JWT_SECRET=your-super-secret-jwt-key
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Blockchain & Web3
INFURA_KEY=your-infura-api-key
SOLANA_RPC=https://api.mainnet-beta.solana.com
WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Stock Market
ALPHA_VANTAGE_KEY=your-alpha-vantage-api-key

# Firestore / Firebase (optional)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Payment / Deposit (optional)
DEPOSIT_URL=https://paypal.me/yourhandle

# CAPTCHA Solving (optional)
CAPTCHA_API_KEY=your-2captcha-api-key

# Google Vision OCR (optional)
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Admin Security
ADMIN_KEY=your-admin-secret-key

# XMR Mining Pool (optional)
XMR_POOL_URL=pool.supportxmr.com:3333

# All keys below are optional extras from your other projects
# (They are not used by onroadnow but kept for reference)
# ============================================================
