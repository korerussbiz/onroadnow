{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/features", "dest": "/public/features.html" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/auto-trader", "dest": "/public/auto-trader.html" },
    { "src": "/stock-trader", "dest": "/public/stock-trader.html" },
    { "src": "/claimer", "dest": "/public/claimer.html" },
    { "src": "/referral", "dest": "/public/referral.html" },
    { "src": "/roundup", "dest": "/public/roundup.html" },
    { "src": "/receipt-invest", "dest": "/public/receipt-invest.html" },
    { "src": "/history", "dest": "/public/history.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
